# =============================================
# BEPC Mada — Variables d'environnement
# Copier ce fichier en .env.local et remplir
# =============================================

# Supabase (depuis Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key

# Supabase service role (serveur uniquement — NE JAMAIS exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# Anthropic Claude API (serveur uniquement)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BEPC_TZ=Africa/Antananarivo

# Admin (email du premier compte admin, créé via bootstrap script)
ADMIN_BOOTSTRAP_EMAIL=admin@bepcmada.mg
